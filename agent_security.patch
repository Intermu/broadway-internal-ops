+// Sanitizer for AI-generated email HTML. The Anthropic prompt instructs the
+// model to emit only <p> tags, but the model is not a security boundary and
+// the resulting email goes to a wider distribution. This sanitizer:
+//   1. Parses the input as HTML using a detached document (no script execution)
+//   2. Walks the tree, replacing any element NOT in the allowlist with its
+//      text-only content (so a malformed <p> still shows its words to the team)
+//   3. For <script>, <style>, and similar code-bearing tags, drops content too
+//      (we don't want CSS or JS source surviving as plain text either)
+//   4. Strips ALL attributes (no event handlers, no javascript: URLs, no
+//      style blocks that could exfiltrate via background-image:url(...))
+// If parsing fails or input is empty, falls back to escapeHtml so we always
+// emit safe content. Used when the model's output is interpolated into the
+// downloadable email HTML.
+function sanitizeAiHtml(input) {
+  if (!input) return '';
+  // Allowlist matches what the prompt requests + minimal text formatting.
+  const ALLOWED = new Set(['P', 'BR', 'STRONG', 'EM', 'B', 'I']);
+  // For these tags, drop the contents entirely — there's no scenario where
+  // a <script>...<\/script> body's text should appear as visible text.
+  const DROP_CONTENTS = new Set(['SCRIPT', 'STYLE', 'TEMPLATE', 'NOSCRIPT', 'IFRAME', 'OBJECT', 'EMBED']);
+  try {
+    const doc = new DOMParser().parseFromString('<div>' + String(input) + '</div>', 'text/html');
+    const root = doc.body.firstChild;
+    if (!root) return escapeHtml(input);
+    const walk = (node) => {
+      if (node.nodeType === 3) return escapeHtml(node.nodeValue); // text node
+      if (node.nodeType !== 1) return ''; // comments, etc.
+      const tag = node.tagName;
+      if (DROP_CONTENTS.has(tag)) return ''; // drop tag AND contents
+      const inner = Array.from(node.childNodes).map(walk).join('');
+      if (ALLOWED.has(tag)) {
+        return '<' + tag.toLowerCase() + '>' + inner + '</' + tag.toLowerCase() + '>';
+      }
+      return inner; // disallowed tag: keep contents (text), drop element + attrs
+    };
+    return Array.from(root.childNodes).map(walk).join('');
+  } catch (e) {
+    // Defensive: if anything goes wrong, fall through to plain-text escape.
+    return escapeHtml(input);
+  }
+}
