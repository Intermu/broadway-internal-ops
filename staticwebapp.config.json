{
  "auth": {
    "rolesSource": "/api/get-roles",
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/5d29e421-2346-4bac-98ee-302668e933e5/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
  {
    "route": "/.auth/*"
  },
  {
    "route": "/api/get-roles",
    "allowedRoles": ["anonymous", "authenticated"]
  },
  {
    "route": "/api/wo-ingest",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/cc-purchase",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/cc-receipt",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/cc-auth",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/ask",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/wo-audit",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/scrape-contacts",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/enrich-contacts",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/vendor-prospects",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/user-role",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/hvac-benchmark",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/send-bid",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/track-open",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/bid-status",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/api/*",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/login",
    "redirect": "/.auth/login/aad"
  },
  {
    "route": "/logout",
    "redirect": "/.auth/logout"
  },
  {
    "route": "/Pilot_Proposal_Diagnostic.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/Broadway_Unified_Ops_Dashboard.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/WO_Audit_Automation.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/wo-audit",
    "rewrite": "/WO_Audit_Automation.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/PIPRoadmap*",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/Broadway_Coordinator_CheckIn.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/assets/*",
    "allowedRoles": ["anonymous"]
  },
  {
    "route": "/board",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/list",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/timeline",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/reports",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/prospects",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/agent",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/dashboard",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/diagnostic",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/check-in",
    "rewrite": "/Broadway_Projects_Tracker.html",
    "allowedRoles": ["broadway_employee"]
  },
  {
    "route": "/*",
    "allowedRoles": ["broadway_employee"]
  }
 ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js": "text/javascript"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.html", "/*.js", "/api/*", "/.auth/*", "/assets/*"]
  }
}
